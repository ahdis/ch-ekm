@startuml

node "Healthcare Provider" {
  [Clinic Database / EHR] as EHR
  [Responsible Physician] as Doc
}

node "Private Service Provider" {
  [Broker] as Broker
}

node "Public Health" {
  [FOPH Reporting System] as FOPH
}

' --- Relations ---
Doc -right-> EHR : Enters Clinical Findings (Diagnosis, Symptoms, Risks,...)

' Using -right-> instead of -down-> to stretch the width
Broker -left-> EHR : Accesses  Data
Broker -right-> FOPH : Transmits Clinical Report


@enduml