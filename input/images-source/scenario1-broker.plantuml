@startuml
' Forzamos una disposición de izquierda a derecha más compacta
skinparam componentStyle rectangle
skinparam nodesep 10
skinparam ranksep 20

rectangle "Healthcare Provider" as HP {
  component "Treating Physician" as Doc
  component "Clinic Database / EHR" as EHR
}

rectangle "Private Service Provider" as PSP {
  component "Broker" as Broker
}

rectangle "Public Health" as PH {
  component "FOPH Reporting System" as FOPH
}

' --- Relations ---
' Usamos una sola flecha de dirección para mantener la linealidad
Doc -> EHR : Enters Clinical Findings\n(Diagnosis, Symptoms, Risks,...)
EHR <- Broker : Accesses Data
Broker -> FOPH : Transmits Clinical Report

@enduml